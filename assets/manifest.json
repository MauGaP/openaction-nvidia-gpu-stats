{
	"Name": "NVIDIA GPU Stats",
	"Author": "maugap",
	"Version": "0.2.0",
	"Category": "NVIDIA GPU Stats",
	"Icon": "icon",
	"OS": [{ "Platform": "linux" }],
	"CodePaths": {
		"x86_64-unknown-linux-gnu": "oanvgpustats-x86_64-unknown-linux-gnu",
		"aarch64-unknown-linux-gnu": "oanvgpustats-aarch64-unknown-linux-gnu"
	},
	"CodePathLin": "oanvgpustats-x86_64-unknown-linux-gnu",
	"PropertyInspectorPath": "pi.html",
	"Actions": [
		{
			"UUID": "dev.maugap.oanvgpustats.usage",
			"Name": "GPU Usage",
			"Icon": "icon",
			"Tooltip": "Displays GPU utilisation (NVIDIA via nvidia-smi)",
			"Controllers": ["Keypad", "Encoder"],
			"States": [{ "Title": "0%", "FontSize": 16 }]
		},
		{
			"UUID": "dev.maugap.oanvgpustats.temperature",
			"Name": "GPU Temperature",
			"Icon": "icon",
			"Tooltip": "Displays GPU temperature (NVIDIA via nvidia-smi)",
			"Controllers": ["Keypad", "Encoder"],
			"States": [{ "Title": "--°C", "FontSize": 18 }]
		},
		{
			"UUID": "dev.maugap.oanvgpustats.memory",
			"Name": "GPU Memory",
			"Icon": "icon",
			"Tooltip": "Displays GPU memory used / total (NVIDIA via nvidia-smi)",
			"Controllers": ["Keypad", "Encoder"],
			"States": [{ "Title": "0GB", "FontSize": 12 }]
		},
		{
			"UUID": "dev.maugap.oanvgpustats.power",
			"Name": "GPU Power",
			"Icon": "icon",
			"Tooltip": "Displays GPU power draw in watts (NVIDIA via nvidia-smi)",
			"Controllers": ["Keypad", "Encoder"],
			"States": [{ "Title": "0W", "FontSize": 16 }]
		}
	]
}
